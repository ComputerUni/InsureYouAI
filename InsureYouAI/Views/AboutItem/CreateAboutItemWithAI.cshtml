@{
    ViewData["Title"] = "AI ile Yeni Hakkımda Maddesi Oluştur";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-robot me-2"></i>
                        AI ile Oluşturulan Hakkımızda Maddeleri
                    </h4>
                </div>
                <div class="card-body">
                    @foreach (var item in ((string)ViewBag.aboutItem).Split('\n', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <p class="text-muted" style="line-height: 1.8;">@item</p>
                    }
                </div>
                <div class="card-footer text-end">
                    <a asp-action="AboutItemList" class="btn btn-outline-secondary me-2">Geri Dön</a>
                    <a asp-action="CreateAboutItemWithAI" class="btn btn-primary">Yeniden Oluştur</a>
                </div>
            </div>
        </div>
    </div>
</div>