@model Article
@{
    ViewData["Title"] = "Yeni Makale Oluştur";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <div class="d-flex align-items-center mb-4">
            <h5 class="mb-0 fw-bold text-primary">Makale Ekleme Sayfası</h5>
            <form class="ms-auto position-relative">
                <div class="position-absolute top-50 translate-middle-y search-icon px-3">
                    <i class="bi bi-search text-muted"></i>
                </div>
                <input class="form-control ps-5 rounded-pill" type="text" placeholder="Makale ara...">
            </form>
        </div>
        <hr />
        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">Başlık</label>
                <input type="text" asp-for="Title" class="form-control form-control-lg" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Kapak Fotoğrafı URL</label>
                <input type="text" asp-for="CoverImageUrl" class="form-control form-control-lg" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Makale Detay Kapak Görsel</label>
                <input type="text" asp-for="MainCoverImageUrl" class="form-control form-control-lg" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Kategori</label>
                <input type="text" asp-for="CategoryId" class="form-control form-control-lg" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">İçerik</label>
                <textarea rows="10" asp-for="Content" class="form-control form-control-lg"></textarea>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4 shadow-sm">
                    <i class="bi bi-plus-circle me-1"></i> Makale Oluştur
                </button>
            </div>
        </form>
    </div>
</div>