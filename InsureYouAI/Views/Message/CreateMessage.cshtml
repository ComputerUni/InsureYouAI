@model Message
@{
    ViewData["Title"] = "Yeni Mesaj Oluştur";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <div class="d-flex align-items-center mb-4">
            <h5 class="mb-0 fw-bold text-primary">Mesaj Ekleme Sayfası</h5>
            <form class="ms-auto position-relative">
                <div class="position-absolute top-50 translate-middle-y search-icon px-3">
                    <i class="bi bi-search text-muted"></i>
                </div>
                <input class="form-control ps-5 rounded-pill" type="text" placeholder="Mesaj ara...">
            </form>
        </div>
        <hr />
        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">Ad Soyad</label>
                <input type="text" asp-for="NameSurname" class="form-control form-control-lg" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Konu</label>
                <input type="text" asp-for="Subject" class="form-control form-control-lg" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input type="email" asp-for="Email" class="form-control form-control-lg" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Mesaj Detayı</label>
                <textarea asp-for="MessageDetail" rows="5" class="form-control form-control-lg"></textarea>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4 shadow-sm">
                    <i class="bi bi-plus-circle me-1"></i> Mesaj Oluştur
                </button>
            </div>
        </form>
    </div>
</div>