@{
    ViewData["Title"] = "AI ile Servis Oluştur";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-robot me-2"></i>
                        AI ile Oluşturulan Servisler
                    </h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.services != null)
                    {
                        <ul class="list-unstyled">
                            @foreach (var service in (List<string>)ViewBag.services)
                            {
                                <li class="mb-3 p-3 border rounded">
                                    <i class="bi bi-check-circle-fill text-primary me-2"></i>
                                    @service
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-3 text-muted">Metin oluşturuluyor...</p>
                        </div>
                    }
                </div>
                <div class="card-footer text-end">
                    <a asp-action="ServiceList" class="btn btn-outline-secondary me-2">Geri Dön</a>
                    <a asp-action="CreateServiceWithAI" class="btn btn-primary">Yeniden Oluştur</a>
                </div>
            </div>
        </div>
    </div>
</div>