@model AboutItem
@{
    ViewData["Title"] = "Yeni Hakkımda Bölümü Oluştur";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <div class="d-flex align-items-center mb-4">
            <h5 class="mb-0 fw-bold text-primary">Yeni Hakkımda Bölümü Madde Girişi</h5>
        </div>
        <hr />
        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">İçerik</label>
                <input type="text" asp-for="Detail" class="form-control form-control-lg" />
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4 shadow-sm">
                    <i class="bi bi-plus-circle me-1"></i> Alanı Kaydet
                </button>
            </div>
        </form>
    </div>
</div>
