@model Category
@{
    ViewData["Title"] = "Kategori Güncelle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <div class="d-flex align-items-center mb-4">
            <h5 class="mb-0 fw-bold text-primary">Sigorta Kategori Düzenleme Sayfası</h5>
        </div>

        <hr />

        <form method="post">
            <div class="mb-3">
                <input type="hidden" asp-for="CategoryId" />
                <label class="form-label fw-semibold">Kategori Adı</label>
                <input type="text" asp-for="CategoryName" class="form-control form-control-lg" placeholder="Örn: Sağlık Sigortası" />
                <span asp-validation-for="CategoryName" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4 shadow-sm">
                    <i class="bi bi-plus-circle me-1"></i> Kategoriyi Düzenle
                </button>
            </div>
        </form>
    </div>
</div>
